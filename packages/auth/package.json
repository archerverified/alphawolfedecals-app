{
  "name": "@alphawolf/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "node": "./dist/server.js",
      "default": "./src/server.ts"
    },
    "./email": {
      "types": "./src/email.ts",
      "node": "./dist/email.js",
      "default": "./src/email.ts"
    },
    "./next": {
      "types": "./src/next.ts",
      "node": "./dist/next.js",
      "default": "./src/next.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@alphawolf/db": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "next-auth": "5.0.0-beta.31",
    "resend": "^6.14.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
