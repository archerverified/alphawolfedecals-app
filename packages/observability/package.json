  },
  "peerDependencies": {
    "@sentry/core": ">=8"
  },
  "devDependencies": {
    "@sentry/core": "^10.62.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
