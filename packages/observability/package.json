{
  "name": "@alphawolf/observability",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    }
