{
  "name": "@alphawolf/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "prisma"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit --passWithNoTests",
    "test:integration": "dotenv -e .env -- vitest run --project integration",
    "postinstall": "prisma generate",
    "prisma:generate": "dotenv -e .env -- prisma generate",
    "prisma:push": "dotenv -e .env -- prisma db push",
    "prisma:migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
    "db:setup": "pnpm prisma:push --skip-generate && pnpm db:apply-sql",
    "db:migrate": "pnpm prisma:migrate:deploy && pnpm db:apply-sql",
    "db:apply-sql": "dotenv -e .env -- sh -c 'psql \"$DIRECT_URL\" -v ON_ERROR_STOP=1 -f prisma/sql/auth_rls.sql'",
    "db:seed": "dotenv -e .env -- tsx seeds/index.ts",
    "db:seed-aw": "dotenv -e .env -- tsx scripts/seed-vehicle-templates.ts",
    "db:make-admin": "dotenv -e .env -- tsx scripts/make-admin.ts",
    "storage:provision": "dotenv -e .env -- tsx scripts/provision-storage.ts",
    "storage:migrate-local": "dotenv -e .env -- tsx scripts/migrate-local-assets.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.108.1",
    "prisma": "^5.22.0",
    "sharp": "^0.35.0",
    "svgo": "^3.3.3",
    "svgson": "^5.3.1"
  },
  "devDependencies": {
    "@alphawolf/canvas": "workspace:^",
    "@types/node": "^22.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx seeds/index.ts"
  }
}
