// Alpha Wolf Wrap Studio — Prisma schema.
// RLS policies + pgcrypto helpers live in prisma/sql/auth_rls.sql and are applied
// after `prisma db push` / `prisma migrate deploy`. See ADR-0002 for the
// app.current_user_id session-variable pattern.

generator client {
  provider      = "prisma-client-js"
  // native     — local dev (macOS arm64 / linux x64)
  // rhel-openssl-3.0.x — Vercel serverless lambda runtime (Amazon Linux 2023, OpenSSL 3)
  // debian-openssl-3.0.x — Render web services (Debian 12 / Ubuntu 22.04, OpenSSL 3)
  // Listing all three ensures `prisma generate` produces a binary for every
  // deploy target up front; without these explicit targets, the lambda crashes
  // at runtime with PrismaClientInitializationError "couldn't find a query engine"
  // because the build machines binary doesn't match the lambdas libc/openssl.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  customer
  shop_user
}

enum AccountStatus {
  pending_verification
  active
  locked
  deleted
}

enum MembershipRole {
  shop_admin
  shop_designer
}

enum AuthEventType {
  signup
  login
  login_failed
  logout
  otp_requested
  otp_verified
  otp_failed
  password_reset_requested
  password_reset_completed
  account_locked
  ip_locked
}

// Users. PII (name, email, phone) is encrypted at rest via pgcrypto.
// email_lower_hash is an HMAC-SHA256 of the lowercase email, used for deterministic
// lookup without exposing the plaintext to indexes or logs.
model User {
  id                 String        @id @default(uuid()) @db.Uuid
  emailEncrypted     Bytes         @map("email_encrypted")
  emailLowerHash     Bytes         @unique @map("email_lower_hash")
  firstNameEncrypted Bytes         @map("first_name_encrypted")
  lastNameEncrypted  Bytes         @map("last_name_encrypted")
  phoneEncrypted     Bytes?        @map("phone_encrypted")
  passwordHash       String        @map("password_hash")
  accountType        AccountType   @map("account_type")
  // Internal Alpha Wolf staff flag. Separate from account_type (which is
  // permanent and constrained to customer | shop_user). Gates the admin
  // vehicle-template CRUD routes and is the subject the vehicle RLS policies
  // check via app_is_admin(). See ADR-0005.
  isAdmin            Boolean       @default(false) @map("is_admin")
  status             AccountStatus @default(pending_verification)
  failedLoginCount   Int           @default(0) @map("failed_login_count")
  lockedUntil        DateTime?     @map("locked_until")
  lastLoginAt        DateTime?     @map("last_login_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  memberships      Membership[]
  otpCodes         OtpCode[]
  authEvents       AuthEvent[]
  verifiedVehicles Vehicle[]                @relation("VehicleVerifiedBy")
  templateRequests VehicleTemplateRequest[]

  @@index([accountType])
  @@index([status])
  @@map("users")
}

// Shops. company_name is encrypted; receive_code is a 12-char public handoff
// token for project transfer (GH-012) — not secret.
model Shop {
  id                   String   @id @default(uuid()) @db.Uuid
  companyNameEncrypted Bytes    @map("company_name_encrypted")
  websiteEncrypted     Bytes?   @map("website_encrypted")
  addressEncrypted     Bytes?   @map("address_encrypted")
  receiveCode          String   @unique @map("receive_code") @db.VarChar(12)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  memberships Membership[]

  @@map("shops")
}

model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  shopId    String         @map("shop_id") @db.Uuid
  role      MembershipRole
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
  @@map("memberships")
}

// One-time codes for email verification, password reset, etc.
// code_hash stores an argon2id hash of the 6-digit code (codes are never stored in clear).
// attempts caps wrong-code guesses (5 per code per 15 min — see PRD §10.1).
model OtpCode {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash")
  purpose    String    @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, consumedAt])
  @@index([expiresAt])
  @@map("otp_codes")
}

// Audit log of all auth events. user_id is nullable for events that happen before
// the user identity is established (e.g. failed login against unknown email).
model AuthEvent {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  eventType AuthEventType @map("event_type")
  ipAddress String?       @map("ip_address") @db.VarChar(64)
  userAgent String?       @map("user_agent")
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@map("auth_events")
}

// Sliding-window rate-limit + lockout tracking. Keyed by a string that encodes
// the bucket (e.g. "ip:1.2.3.4:login", "account:<userId>:login").
model RateLimit {
  key           String    @id @db.VarChar(255)
  attempts      Int       @default(0)
  resetAt       DateTime  @map("reset_at")
  lockedUntil   DateTime? @map("locked_until")
  lastAttemptAt DateTime  @default(now()) @map("last_attempt_at")

  @@index([resetAt])
  @@map("rate_limits")
}

// ----------------------------------------------------------------------------
// Vehicle template library (GH-003 / GH-004 / GH-017).
// Schema mirrors docs/vehicle-database-spec.md §2 exactly. Vehicle templates are
// shared, public, non-PII resources — they are NOT encrypted via pgcrypto.
// RLS (public read of published rows, admin-only writes) lives in
// prisma/sql/auth_rls.sql. The expression/partial indexes the spec mandates
// (tsvector full-text, pg_trgm typo-tolerant search, the published partial
// unique key) and the year CHECK constraint are not expressible in the Prisma
// schema language, so they are appended as raw SQL in the migration.
// ----------------------------------------------------------------------------

enum BodyType {
  sedan
  suv
  crossover
  pickup
  van
  box_truck
  sprinter
  motorcycle
  rv
  trailer
  boat
  equipment

  @@map("body_type")
}

enum TemplateStatus {
  draft
  review
  published
  retired

  @@map("template_status")
}

enum SourceAuthority {
  manufacturer_spec
  measured_in_shop
  licensed
  community_verified

  @@map("source_authority")
}

enum FinishHint {
  gloss
  satin
  matte
  chrome
  carbon
  brushed
  none

  @@map("finish_hint")
}

model Vehicle {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year     Int
  make     String
  model    String
  trim     String?
  variant  String?
  bodyType BodyType @map("body_type")

  // Universal dimensions (millimetres).
  lengthMm    Int  @map("length_mm")
  widthMm     Int  @map("width_mm")
  heightMm    Int  @map("height_mm")
  wheelbaseMm Int? @map("wheelbase_mm")

  // Body-type-specific facets (nullable per type).
  cabSize    String? @map("cab_size")
  bedSize    String? @map("bed_size")
  roofHeight String? @map("roof_height")
  doorCount  Int?    @map("door_count")

  // Templating assets.
  outlineSvgUrl String  @map("outline_svg_url")
  topviewSvgUrl String? @map("topview_svg_url")
  // ⚠️ STOPGAP DATA (resolves in GH-005). The column name (per spec §2) promises
  // a PNG, and that IS the end state. Until GH-005's raster pipeline lands there
  // are no PNGs, so this PR stores the OUTLINE SVG URL here (renders fine in an
  // <img>). GH-005 must write a real PNG URL — which makes the name honest and
  // ends the mismatch. Do not build anything that assumes the bytes are PNG yet.
  thumbPngUrl   String  @map("thumb_png_url")

  // Alpha Wolf wrapped-template fields (Goal 2a). Nullable because this table is
  // heterogeneous — it also holds non-AW rows with no wrap. The seed populates
  // all of these for AW rows; CHECK constraints (view_count 1..4, tpl-id format)
  // live in the migration since Prisma can't express them. svgStorageKey is the
  // bucket-relative key of the wrapped SVG in the public vehicle-templates bucket
  // (rendered via storage.templatePublicUrl). The AW frame is baked in by
  // wrap_template.py — do NOT wrap again at render time.
  svgStorageKey  String? @unique @map("svg_storage_key")
  viewCount      Int?    @map("view_count") @db.SmallInt
  dimensionsText String? @map("dimensions_text")
  scaleDenom     Int     @default(20) @map("scale_denom") @db.SmallInt
  alphaWolfTplId String? @unique @map("alpha_wolf_tpl_id")

  // Provenance.
  sourceAuthority SourceAuthority @map("source_authority")
  sourceNotes     String?         @map("source_notes")
  verifiedAt      DateTime?       @map("verified_at") @db.Timestamptz
  verifiedById    String?         @map("verified_by") @db.Uuid

  // Versioning.
  version      Int            @default(1)
  status       TemplateStatus @default(draft)
  supersedesId String?        @map("supersedes_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  verifiedBy      User?                    @relation("VehicleVerifiedBy", fields: [verifiedById], references: [id])
  supersedes      Vehicle?                 @relation("VehicleSupersedes", fields: [supersedesId], references: [id])
  supersededBy    Vehicle[]                @relation("VehicleSupersedes")
  panels          VehiclePanel[]
  shippedRequests VehicleTemplateRequest[] @relation("RequestShippedVehicle")
  projects        Project[]

  @@index([year, make, model], map: "vehicles_year_make_model_idx")
  @@map("vehicles")
}

model VehiclePanel {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId        String     @map("vehicle_id") @db.Uuid
  name             String
  svgPath          String     @map("svg_path")
  view             String
  wrapSafeZone     Json       @map("wrap_safe_zone")
  // ⚠️ CROSS-PR COUPLING (GH-005 -> GH-010). 0 is a SENTINEL meaning "surface
  // area not yet computed", NOT a real zero area. This PR (GH-003/004) writes 0
  // because the geometry precompute is the paneling pipeline (out of scope).
  // GH-005 must populate this with the real precomputed area; GH-010 (print
  // paneling) MUST treat 0 as "missing data" and refuse to panel — never feed it
  // into area math, or a template paneled with area 0 prints to nothing. When
  // GH-005 lands, add `CHECK (printable_area_mm2 > 0)` here to make the
  // guarantee enforceable.
  printableAreaMm2 Int        @map("printable_area_mm2")
  finishHint       FinishHint @default(none) @map("finish_hint")
  installOrder     Int        @map("install_order")
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId], map: "vehicle_panels_vehicle_idx")
  @@map("vehicle_panels")
}

model VehicleTemplateRequest {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId        String?   @map("requester_id") @db.Uuid
  // Stored only when the requester opts in to ship notifications. Left NULL on
  // opt-out so no follow-up email can be sent (GH-017 email opt-out).
  requesterEmail     String?   @map("requester_email")
  year               Int
  make               String
  model              String
  trim               String?
  variant            String?
  referencePhotoUrls String[]  @map("reference_photo_urls")
  notes              String?
  status             String    @default("pending")
  shippedVehicleId   String?   @map("shipped_vehicle_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt         DateTime? @map("resolved_at") @db.Timestamptz

  requester      User?    @relation(fields: [requesterId], references: [id])
  shippedVehicle Vehicle? @relation("RequestShippedVehicle", fields: [shippedVehicleId], references: [id])

  @@index([status, createdAt])
  @@map("vehicle_template_requests")
}

// ----------------------------------------------------------------------------
// Customer projects + canvas editor persistence (GH-005 / GH-008). See ADR-0006
// (canvas data model / persistence) and ADR-0007 (asset storage).
//
// Ownership is scoped by RLS via app.current_user_id (prisma/sql/auth_rls.sql),
// mirroring the user-owned auth tables — owner_user_id is a plain Uuid column,
// not a Prisma relation, so user soft-delete doesn't cascade-wipe project data.
// canvas_state is opaque JSONB to @alphawolf/db; the apps/web Server Action runs
// the @alphawolf/canvas migrate/validate round-trip before it ever lands here.
// ----------------------------------------------------------------------------

enum ProjectStatus {
  draft
  active
  deleted

  @@map("project_status")
}

// Lifecycle of a project_versions row. `working` is the single mutable autosave
// target; a milestone freezes that row (submitted/approved/rejected) and clones
// a new `working` row forward (see ADR-0006 §4).
enum ApprovalState {
  working
  submitted
  approved
  rejected

  @@map("approval_state")
}

// Parse pipeline status for an uploaded asset (services/parse). queued_missing_cli
// means a vector job (AI/EPS/PDF) was accepted but inkscape/pdf2svg is absent on
// the worker host — the editor surfaces "waiting on dependency" instead of failing.
enum AssetParseStatus {
  pending
  processing
  parsed
  failed
  queued_missing_cli

  @@map("asset_parse_status")
}

// Production order lifecycle (Goal 3a PR5). MVP: a customer "submits for
// production" with delivery details and no payment. The shop dashboard (Goal 3b)
// drives the status transitions; email notifications land in Goal 3c.
enum OrderStatus {
  submitted
  in_production
  fulfilled
  cancelled

  @@map("order_status")
}

model Project {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId   String        @map("owner_user_id") @db.Uuid
  ownerShopId   String?       @map("owner_shop_id") @db.Uuid
  vehicleId     String        @map("vehicle_id") @db.Uuid
  // User-facing project name (rename CRUD, GH-008). Defaulted at creation from
  // the chosen vehicle label; editable.
  name          String        @default("Untitled project")
  status        ProjectStatus @default(draft)
  // 12-char public handoff token for project transfer (GH-012). Not secret.
  transferToken String?       @unique @map("transfer_token")
  // Set when status flips to `deleted`; drives the 30-day recovery window (PRD §8.2).
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vehicle  Vehicle          @relation(fields: [vehicleId], references: [id])
  versions ProjectVersion[]
  assets   ProjectAsset[]
  orders   Order[]

  @@index([ownerUserId, status])
  @@map("projects")
}

model ProjectVersion {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String        @map("project_id") @db.Uuid
  version       Int
  canvasState   Json          @map("canvas_state")
  approvalState ApprovalState @default(working) @map("approval_state")
  // Optimistic-concurrency token for single-editor last-write-wins (ADR-0006 §4).
  // Each autosave UPDATE bumps it; the action sends the rev it loaded with.
  rev           Int           @default(0)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([projectId, version])
  @@index([projectId, approvalState])
  @@map("project_versions")
}

model ProjectAsset {
  assetId       String           @id @default(dbgenerated("gen_random_uuid()")) @map("asset_id") @db.Uuid
  projectId     String           @map("project_id") @db.Uuid
  ownerUserId   String           @map("owner_user_id") @db.Uuid
  mimeType      String           @map("mime_type")
  // Bucket-relative storage key of the uploaded original (project-assets bucket).
  sourceUrl     String           @map("source_url")
  // Storage key of the parse worker's output (SVG / cleaned raster). Null until parsed.
  parsedUrl     String?          @map("parsed_url")
  parseStatus   AssetParseStatus @default(pending) @map("parse_status")
  // Worker-written context: dimensions, bbox, rembg flag, error detail, etc.
  parseMetadata Json?            @map("parse_metadata")
  // Bumped when a re-parse supersedes prior output, so the editor can invalidate
  // cached canvas references to this asset (ADR-0009 version vectors).
  version       Int              @default(1)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_assets")
}

// A submitted production order (Goal 3a PR5). Created when the customer clicks
// "Submit for production": the working canvas version is frozen to `submitted`
// and this row pins that frozen version + the delivery/contact details. No
// payment in the MVP. `ownerShopId` is the routing shop the dashboard (Goal 3b)
// reads; copied from the project at submit time.
model Order {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String      @map("project_id") @db.Uuid
  projectVersionId String      @map("project_version_id") @db.Uuid
  ownerUserId      String      @map("owner_user_id") @db.Uuid
  ownerShopId      String?     @map("owner_shop_id") @db.Uuid
  status           OrderStatus @default(submitted)
  contactName      String      @map("contact_name")
  contactEmail     String      @map("contact_email")
  contactPhone     String?     @map("contact_phone")
  deliveryNotes    String?     @map("delivery_notes")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@index([ownerShopId, status])
  @@map("orders")
}
