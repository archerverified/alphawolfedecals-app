# --- Postgres / Supabase ---
# Superuser/owner connection. Used by Prisma migrations and by withSystem()
# bootstrap paths (signup, OTP, login) that must run before a user is
# authenticated. Bypasses RLS — keep it off the authenticated request path.
DATABASE_URL=
# Non-superuser (app_user) runtime connection for authenticated request paths
# (withUser). Same host/params as DATABASE_URL but the app_user role, which is
# NOBYPASSRLS, so Postgres RLS policies actually enforce row visibility. If
# unset, @alphawolf/db falls back to DATABASE_URL and logs an RLS-bypass
# warning. Required before production. See ADR-0002 and prisma/sql/auth_rls.sql.
DATABASE_URL_APP=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# 32+ byte secret used by Auth.js to sign JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=
# 32+ byte symmetric key used by pgcrypto to encrypt PII (name, email, phone).
# Generate with: openssl rand -base64 32. Do NOT rotate without a planned migration.
PII_ENCRYPTION_KEY=

# --- Email ---
RESEND_API_KEY=
# Phase 1: onboarding@resend.dev (sandbox; only delivers to Resend account owner).
# Phase 4: switch to no-reply@alphawolfwrap.com after domain verification.
RESEND_FROM_EMAIL=
# Optional. Set to "console" to skip the Resend API call (still logs to stdout in dev).
AUTH_EMAIL_TRANSPORT=

# --- AI ---
ANTHROPIC_API_KEY=

# --- Observability ---
SENTRY_DSN=
POSTHOG_KEY=

# --- Queue ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
