    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
