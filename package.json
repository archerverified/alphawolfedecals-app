{
  "name": "alphawolf-wrap-studio",
  "private": true,
  "version": "0.0.0",
  "description": "Alpha Wolf Wrap Studio monorepo",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "8.5.14",
      "ioredis": "5.11.1"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "prepare": "husky || true",
    "render:install": "corepack enable && pnpm install --frozen-lockfile --prod=false && pnpm --filter @alphawolf/db prisma:generate",
    "render:build:api": "pnpm turbo run build --filter=@alphawolf/api",
    "render:build:parse": "pnpm turbo run build --filter=@alphawolf/parse"
  },
  "devDependencies": {
    "@alphawolf/auth": "workspace:*",
    "@alphawolf/db": "workspace:*",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/node": "^22.9.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0"
  }
}
